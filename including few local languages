  if (score >= 80) return 'linear-gradient(90deg,#52b788,#2d6a4f)';
  if (score >= 60) return 'linear-gradient(90deg,#ffd166,#f4a261)';
  if (score >= 40) return 'linear-gradient(90deg,#f4a261,#e76f51)';
