// ═══ LANG DETECT FROM SCRIPT ═══
function detectLang(t){
  if(/[஀-௿]/.test(t))return"ta";
  if(/[ঀ-৿]/.test(t))return"bn";
  if(/[ಀ-೿]/.test(t))return"kn";
  if(/[ഀ-ൿ]/.test(t))return"ml";
  if(/[ఀ-౿]/.test(t))return"te";
  if(/[ऀ-ॿ]/.test(t))return curLang==="mr"?"mr":"hi";
  return"en";
}

// ═══ FARMER MIC ═══
function setupMic(){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  const btn=document.getElementById("mic-btn"),vsf=document.getElementById("vsf");
  if(!SR){
    document.getElementById("mlbl").textContent="⚠️ Use Google Chrome for voice features";
    btn.style.opacity=".4";btn.style.cursor="not-allowed";btn.onclick=null;return;
  }
  btn.onclick=toggleRec;
  vsf.textContent=T("voiceHint");vsf.classList.add("on");
}

function toggleRec(){if(isRec)stopRec();else startRec();}

function startRec(){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR)return;
  const lc=L[curLang]?.c||"en-IN";
  recObj=new SR();
  recObj.lang=lc;
  recObj.interimResults=true;
  recObj.continuous=false;
  recObj.maxAlternatives=3;
  const btn=document.getElementById("mic-btn"),lbl=document.getElementById("mlbl"),
        tb=document.getElementById("tbox"),badge=document.getElementById("lbadge"),vsf=document.getElementById("vsf");
  recObj.onstart=()=>{
    isRec=true;btn.classList.add("rec");
    lbl.textContent=T("listening");tb.style.fontStyle="normal";tb.textContent="";badge.style.display="none";
    vsf.textContent="🎙️ Listening…";vsf.classList.add("on");
  };
  recObj.onresult=(e)=>{
    let interim="",final_="";
    for(let i=e.resultIndex;i<e.results.length;i++){
      const t=e.results[i][0].transcript;
      if(e.results[i].isFinal)final_+=t;else interim+=t;
    }
    const text=final_||interim;
    tb.textContent=text;
    const dl=detectLang(text);
    if(dl!=="en"&&L[dl]){badge.textContent="🌐 "+L[dl].n;badge.style.display="inline-block";}
    if(final_)parseVoice(final_);
  };
  recObj.onerror=(e)=>{
    const msgs={"not-allowed":"🚫 Mic access denied — click 🔒 in browser address bar and allow microphone","no-speech":"No speech detected. Please speak clearly and close to mic.","network":"Network error during speech recognition.","audio-capture":"No microphone found on this device.","aborted":"Recording stopped."};
    const msg=msgs[e.error]||("Error: "+e.error);
    vsf.textContent="⚠️ "+msg;vsf.classList.add("on");
    toast(msg.slice(0,55));stopRec();
  };
  recObj.onend=()=>{if(isRec)stopRec();};
  try{recObj.start();}catch(ex){toast("Cannot start mic: "+ex.message);}
}

function stopRec(){
  if(recObj){try{recObj.stop();}catch(e){}}
  isRec=false;
  const btn=document.getElementById("mic-btn"),lbl=document.getElementById("mlbl");
  if(btn)btn.classList.remove("rec");
  if(lbl)lbl.textContent=T("tapToSpeak");
}

// ═══ VOICE PARSE — "23 kg potato for 30" → fills all fields ═══
function parseVoice(text){
  const tl=text.toLowerCase().trim();
  const pn=document.getElementById("pname"),pp=document.getElementById("pprice"),
        pq=document.getElementById("pqty"),pu=document.getElementById("punit"),
        pc=document.getElementById("pcat"),vsf=document.getElementById("vsf");

  // ── Price patterns ──
  const priceRes=[
    /(?:for|at|@|price|worth|₹|rs\.?|rupees?|rupe|விலை|दाम|कीमत|ధర| വില|किमत|মূল্য|ரூபாய்|रुपये|రూపాయలు|ರೂಪಾಯಿ|रुपयांना)\s*(\d+(?:\.\d+)?)/i,
    /(\d+(?:\.\d+)?)\s*(?:rupees?|rs\.?|₹|per\s*kg|per\s*piece|ரூபாய்|रुपये|రూపాయలు|only)/i,
    /(?:at|for)\s*(\d+)$/i,
    /(\d+(?:\.\d+)?)\s*(?:rs|rupe)/i,
  ];
  let price="";
  for(const r of priceRes){const m=tl.match(r);if(m){price=m[1];break;}}

  // ── Quantity + Unit ──
  const qRe=/(\d+(?:\.\d+)?)\s*(kg|kilo|kilograms?|g|gram|grams?|piece|pieces?|pcs|dozen|bundle|bundles?|litre|liter|litres?|lts?|packet|pack|ml)/i;
  let qty="",unit="kg";
  const qm=tl.match(qRe);
  if(qm){
    qty=qm[1];
    const raw=qm[2].toLowerCase();
    const um={kilo:"kg",kilogram:"kg",kilograms:"kg",g:"g",gram:"g",grams:"g",pcs:"piece",pieces:"piece",dozen:"dozen",bundle:"bundle",bundles:"bundle",litre:"litre",liter:"litre",litres:"litre",lts:"litre",l:"litre",packet:"packet",pack:"packet",ml:"g"};
    unit=um[raw]||raw;
  }

  // ── Product Name ──
  let ns=tl
    .replace(/(?:for|at|@|price|worth|₹|rs\.?|rupees?|only|per|விலை|दाम|रुपये|कीमत|ధర| రూపాయలు| വില|ரூபாய்)\s*\d+(?:\.\d+)?/gi,"")
    .replace(/(\d+(?:\.\d+)?)\s*(kg|kilo|kilogram|g|gram|grams?|piece|pieces?|pcs|dozen|bundle|litre|liter|lts?|packet|pack|ml)/gi,"")
    .replace(/\d+(?:\.\d+)?/g,"")
    .replace(/(selling|available|fresh|organic|i\s+have|have|want\s+to|my|today|here|am|is|are|the|a|an|some|this|that)/gi,"")
    .replace(/\s+/g," ").trim();
  const nw=ns.split(" ").filter(w=>w.length>1).slice(0,4);
  const name=nw.map(w=>w.charAt(0).toUpperCase()+w.slice(1)).join(" ").trim();

  // ── Category ──
  let category="Vegetables";
  const nl=name.toLowerCase();
  for(const[kw,cat]of Object.entries(PCAT)){if(nl.includes(kw)){category=cat;break;}}

  // ── Auto-fill ──
  if(name&&!pn.value)pn.value=name;
  if(price)pp.value=price;
  if(qty)pq.value=qty+" "+unit;
  // Set unit dropdown
  const uOpts=pu.options;for(let i=0;i<uOpts.length;i++){if(uOpts[i].value===unit){pu.selectedIndex=i;break;}}
  // Set category dropdown
  const cOpts=pc.options;for(let i=0;i<cOpts.length;i++){if(cOpts[i].value===category){pc.selectedIndex=i;break;}}

  const parts=[];
  if(name)parts.push("📦 "+name);if(qty)parts.push("⚖️ "+qty+" "+unit);
  if(price)parts.push("💰 ₹"+price);if(category)parts.push("🏷️ "+category);
  vsf.textContent=parts.length?"✅ Detected: "+parts.join("  |  "):"⚠️ "+T("voiceHint");
  vsf.classList.add("on");
}

// ═══ AI PRICE — Deterministic, neutral, consistent ═══
function aiPrice(){
  const name=document.getElementById("pname").value.toLowerCase().trim();
  if(!name){toast("Enter product name first");return;}
  let base=0;
  for(const[k,v]of Object.entries(MKT)){if(name.includes(k)){base=v;break;}}
  if(!base){base=50;}
  // Deterministic: hash product name for consistent % factor (85-91%)
  let hash=0;for(const ch of name)hash=(hash*31+ch.charCodeAt(0))&0xffff;
  const factor=0.85+(hash%7)*0.01;
  const suggested=Math.round(base*factor);
  document.getElementById("pprice").value=suggested;
  const vsf=document.getElementById("vsf");
  vsf.textContent=T("aiSuggest")+": ₹"+suggested+" | Market reference: ₹"+base+" | Farmer-competitive pricing";
  vsf.classList.add("on");
  toast("✨ Suggested ₹"+suggested+" (market ref ₹"+base+")");
}

