// ═══ TTS — robust with voice loading ═══
function speakTTS(text,lc){
  if(!window.speechSynthesis)return;
  speechSynthesis.cancel();
  function doSpeak(){
    const u=new SpeechSynthesisUtterance(text);
    u.lang=lc||"en-IN"; u.rate=.88; u.pitch=1;
    // Try to pick a voice matching the target language
    const voices=speechSynthesis.getVoices();
    const langPrefix=lc?lc.split("-")[0]:"en";
    const match=voices.find(v=>v.lang.startsWith(langPrefix))||
                 voices.find(v=>v.lang.startsWith("en"));
    if(match)u.voice=match;
    speechSynthesis.speak(u);
  }
  if(speechSynthesis.getVoices().length>0){doSpeak();}
  else{speechSynthesis.addEventListener("voiceschanged",doSpeak,{once:true}); doSpeak();}
}

function speakIntro(pg){
  const lc=L[curLang]?.c||"en-IN";
  speakTTS(T(pg+"Intro"),lc);
  toast("🔊 Playing…");
}

