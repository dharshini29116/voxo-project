.fr-bar{height:5px;border-radius:4px;background:#e0ede8;margin:4px 0 2px;}
.fr-fill{height:100%;border-radius:4px;transition:width .5s;}
.fr-modal{background:var(--w);border-radius:18px 18px 0 0;padding:1.5rem;width:100%;max-width:480px;max-height:92vh;overflow-y:auto;}
