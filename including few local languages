const SENDER_PHONE="9345654592"; // sender number for demo SMS

async function sendSMSOTP(toPhone, otp){
  // Using fast2sms free API (or fallback to textlocal/2factor)
  // For production use your own API key. This uses a CORS proxy approach.
  try{
    const msg=`Your VOXO OTP is ${otp}. Valid for 5 minutes. Do not share.`;
    // Try fast2sms (requires API key - using demo fallback)
    const res=await fetch(`https://www.fast2sms.com/dev/bulkV2?authorization=DEMO_KEY&sender_id=VOXOTP&message=${encodeURIComponent(msg)}&language=english&route=v3&numbers=${toPhone}`,{method:"GET"}).catch(()=>null);
    return false; // In demo, always show fallback
  }catch(e){return false;}
}

function sendOTP(isResend=false){
  if(!isResend){
    const n=document.getElementById("ln").value.trim(),p=document.getElementById("lp").value.trim(),l=document.getElementById("ll").value;
