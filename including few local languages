// Simulate AI visual analysis using image metadata + product context
function analyzeFreshness() {
  document.getElementById('fr-upload-zone').style.display = 'none';
  document.getElementById('fr-analyzing').style.display = '';
  document.getElementById('fr-result').style.display = 'none';

  const imgEl = document.getElementById('fr-preview');
  const canvas = document.createElement('canvas');
  const ctx = canvas.getContext('2d');
  const img = new Image();
  img.onload = () => {
    canvas.width = Math.min(img.width, 80);
    canvas.height = Math.min(img.height, 80);
    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
    const data = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
    let r=0,g=0,b=0,n=data.length/4;
    for(let i=0;i<data.length;i+=4){r+=data[i];g+=data[i+1];b+=data[i+2];}
    r/=n;g/=n;b/=n;
    computeFreshnessScore(r,g,b);
  };
  img.onerror = () => computeFreshnessScore(120,160,90); // fallback
  img.src = imgEl.src;
}

function computeFreshnessScore(r, g, b) {
  setTimeout(() => {
    const prod = frCurrentProduct;
    const cat = prod ? prod.category : 'Vegetables';

    // Color analysis heuristics by category
    let colorScore = 50;
    const brightness = (r + g + b) / 3;
    const greenDom = g > r && g > b;
    const redDom = r > g && r > b;
    const yellowish = r > 150 && g > 130 && b < 100;

    if (cat === 'Vegetables') {
      colorScore = greenDom ? Math.min(95, 60 + (g - Math.max(r,b)) * 0.7) :
                  (yellowish ? 45 : Math.max(20, 70 - Math.abs(r - g) * 0.4));
    } else if (cat === 'Fruits') {
      colorScore = (redDom || yellowish) ? Math.min(90, 55 + (Math.max(r,g) - b) * 0.5) :
                  greenDom ? 72 : 50;
    } else if (cat === 'Dairy') {
      const whiteness = Math.min(r,g,b) / brightness;
      colorScore = whiteness > 0.85 ? 88 : (whiteness > 0.7 ? 70 : 45);
    } else if (cat === 'Grains') {
      colorScore = (brightness > 140 && brightness < 210) ? 82 : 60;
    } else {
      colorScore = Math.min(85, 40 + brightness * 0.2);
    }

    // Add some natural variance using image pixel spread
    const variance = Math.min(15, Math.abs(r - g) + Math.abs(g - b) * 0.3);
    const rawScore = Math.round(Math.max(15, Math.min(98,
      colorScore + (Math.random() * 10 - 5) - variance * 0.2
    )));

    // Trait scores
    const traits = {
      'Color': Math.round(Math.min(100, rawScore + (Math.random()*12-6))),
      'Texture': Math.round(Math.min(100, rawScore - 5 + (Math.random()*14-7))),
      'Firmness': Math.round(Math.min(100, rawScore + 3 + (Math.random()*10-5))),
      'Aroma': Math.round(Math.min(100, rawScore - 2 + (Math.random()*16-8))),
    };

    const avgTrait = Object.values(traits).reduce((a,b)=>a+b,0)/4;
    const finalScore = Math.round((rawScore * 0.6 + avgTrait * 0.4));

    frCurrentScore = finalScore;
    frCurrentData = { score: finalScore, traits, r, g, b, category: cat };

    showFreshnessResult(finalScore, traits, prod);
  }, 1800 + Math.random() * 800);
}

function getFreshnessGrade(score) {
  if (score >= 80) return { label: '🌟 Excellent Fresh', cls: 'fr-fresh', color: '#2d6a4f' };
  if (score >= 60) return { label: '✅ Good Quality', cls: 'fr-fresh', color: '#2d6a4f' };
  if (score >= 40) return { label: '⚠️ Fair — Use Soon', cls: 'fr-good', color: '#856404' };
  return { label: '❌ Poor — Discount Now', cls: 'fr-poor', color: '#8b0000' };
}

