  const vsf=document.getElementById("vsf");
  vsf.textContent=`📈 Market price ₹${peCurrentOpt} applied from Price Engine`;
  vsf.classList.add("on");
  toast("✅ Price ₹"+peCurrentOpt+" applied!");
}

