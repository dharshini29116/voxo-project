<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0"/>
<title>VOXO – Farm Fresh to You</title>
<style>
:root{--g:#2D6A4F;--gl:#D4EDE0;--gd:#1a3d2d;--o:#F4A261;--ol:#FEF0E6;--od:#7A3B10;--bg:#FAFAF7;--w:#fff;--tx:#1a1a18;--tx2:#5a5a56;--bd:#e0ded8;--r:14px;--rs:9px;--sh:0 2px 14px rgba(45,106,79,.10);}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:"Segoe UI",system-ui,sans-serif;background:var(--bg);color:var(--tx);}
.scr{display:none;min-height:100vh;flex-direction:column;} .scr.on{display:flex;}
.hdr{background:var(--gd);color:#fff;padding:.75rem 1rem;display:flex;align-items:center;justify-content:space-between;gap:.4rem;position:sticky;top:0;z-index:50;}
.hlogo{width:30px;height:30px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,255,255,.3);}
.htitle{font-size:1.05rem;font-weight:800;letter-spacing:1.5px;}
.hr{display:flex;align-items:center;gap:.4rem;}
.pill{display:flex;align-items:center;gap:4px;background:rgba(255,255,255,.15);border-radius:20px;padding:4px 10px;font-size:12px;cursor:pointer;border:none;color:#fff;transition:.2s;}
.pill:hover{background:rgba(255,255,255,.28);}
.cbadge{background:var(--o);color:var(--od);font-size:10px;font-weight:800;border-radius:50%;width:17px;height:17px;display:inline-flex;align-items:center;justify-content:center;}
.main{flex:1;overflow-y:auto;padding:1rem;} .mw{max-width:480px;margin:0 auto;}
/* login */
.lhero{background:linear-gradient(140deg,var(--gd),var(--g));color:#fff;padding:2.5rem 1.5rem 2rem;text-align:center;}
.llogoimg{width:88px;height:88px;border-radius:18px;object-fit:cover;margin-bottom:.75rem;border:3px solid rgba(255,255,255,.3);box-shadow:0 4px 20px rgba(0,0,0,.2);}
.lhero h2{font-size:2rem;font-weight:800;letter-spacing:2px;margin-bottom:.3rem;}
.lhero p{font-size:.88rem;opacity:.85;}
.lbody{padding:1.5rem;max-width:440px;margin:0 auto;width:100%;}
.stitle{font-size:.78rem;font-weight:700;color:var(--tx2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:.75rem;}
.roles{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.5rem;}
.rcard{border:2px solid var(--bd);border-radius:var(--r);padding:1.25rem .75rem;text-align:center;cursor:pointer;background:var(--w);transition:all .2s;}
.rcard:hover{border-color:var(--g);transform:translateY(-2px);} .rcard.sel{border-color:var(--g);background:var(--gl);}
.rico{font-size:36px;margin-bottom:.4rem;} .rtitle{font-weight:700;font-size:.9rem;} .rdesc{font-size:.73rem;color:var(--tx2);margin-top:3px;line-height:1.4;}
.field{margin-bottom:.8rem;}
.field label{display:block;font-size:11px;font-weight:700;color:var(--tx2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
.inp{width:100%;padding:.6rem .85rem;border-radius:var(--rs);border:1px solid var(--bd);font-size:.92rem;outline:none;background:var(--w);transition:.15s;}
.inp:focus{border-color:var(--g);box-shadow:0 0 0 3px rgba(45,106,79,.1);}
.pw{display:flex;border-radius:var(--rs);border:1px solid var(--bd);overflow:hidden;transition:.15s;} .pw:focus-within{border-color:var(--g);}
.ppre{padding:.6rem .75rem;background:#f0ede4;font-weight:700;font-size:.88rem;white-space:nowrap;border-right:1px solid var(--bd);}
.pw input{flex:1;padding:.6rem .75rem;border:none;outline:none;font-size:.92rem;background:transparent;}
select.inp{cursor:pointer;}
.btn{display:block;width:100%;padding:.75rem;border-radius:var(--rs);border:none;font-size:.92rem;font-weight:700;cursor:pointer;transition:all .15s;}
.btn:active{transform:scale(.97);}
.btng{background:var(--g);color:#fff;box-shadow:0 3px 10px rgba(45,106,79,.25);} .btng:hover{opacity:.9;}
.btno{background:var(--o);color:var(--od);} .btnh{background:var(--bg);border:1px solid var(--bd);color:var(--tx2);} .btnh:hover{background:var(--gl);border-color:var(--g);color:var(--gd);}
.blnk{background:none;border:none;color:var(--g);font-size:.85rem;text-decoration:underline;cursor:pointer;padding:0;}
.div{text-align:center;color:var(--tx2);font-size:.78rem;margin:.5rem 0;}
.dlinks{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;}
/* OTP */
.oscr{text-align:center;padding:2rem 1.5rem;max-width:380px;margin:0 auto;}
.orow{display:flex;gap:.4rem;justify-content:center;margin:.75rem 0;}
.ob{width:44px;height:52px;text-align:center;font-size:1.4rem;font-weight:700;border-radius:var(--rs);border:2px solid var(--bd);outline:none;transition:.15s;} .ob:focus{border-color:var(--g);}
.rrow{display:flex;align-items:center;justify-content:center;gap:.5rem;margin-top:.75rem;font-size:.82rem;color:var(--tx2);}
/* stats */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:.55rem;margin-bottom:1.2rem;}
.stat{background:var(--w);border:1px solid var(--bd);border-radius:var(--r);padding:.85rem .4rem;text-align:center;box-shadow:var(--sh);}
.sv{font-size:1.4rem;font-weight:800;color:var(--gd);} .sl{font-size:10px;color:var(--tx2);text-transform:uppercase;letter-spacing:.4px;margin-top:2px;}
.analytics{background:var(--w);border-radius:var(--r);border:1px solid var(--bd);padding:1rem;margin-bottom:1.2rem;box-shadow:var(--sh);}
.analytics h3{font-size:.78rem;font-weight:700;color:var(--tx2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.75rem;}
/* mic panel */
.mcp{background:var(--w);border-radius:var(--r);border:1px solid var(--bd);padding:1.2rem;box-shadow:var(--sh);}
.mcc{display:flex;flex-direction:column;align-items:center;gap:.7rem;margin-bottom:.9rem;}
#mic-btn{width:78px;height:78px;border-radius:50%;background:var(--g);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;box-shadow:0 4px 16px rgba(45,106,79,.35);outline:none;}
#mic-btn:hover{transform:scale(1.05);} #mic-btn.rec{background:#d93025;animation:pulse 1s infinite;}
#mic-btn svg{width:32px;height:32px;fill:#fff;}
#mlbl{font-size:.83rem;color:var(--tx2);text-align:center;}
#lbadge{font-size:11px;background:var(--ol);color:var(--od);padding:3px 10px;border-radius:20px;font-weight:700;display:none;}
#tbox{min-height:50px;background:var(--bg);border:1px dashed var(--bd);border-radius:var(--rs);padding:.7rem;font-size:.88rem;color:var(--tx2);font-style:italic;line-height:1.5;width:100%;margin-bottom:.65rem;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(217,48,37,.4);}50%{box-shadow:0 0 0 16px rgba(217,48,37,0);}}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-top:.6rem;}
.pr{display:flex;gap:.4rem;align-items:center;} .pr .inp{flex:1;}
.aibtn{padding:.5rem .65rem;background:var(--ol);color:var(--od);border:1px solid var(--o);border-radius:var(--rs);font-size:.73rem;font-weight:700;cursor:pointer;white-space:nowrap;transition:.2s;}
.aibtn:hover{background:var(--o);color:#fff;}
.idrop{border:2px dashed var(--bd);border-radius:var(--rs);padding:.9rem;text-align:center;cursor:pointer;font-size:.83rem;color:var(--tx2);transition:.2s;margin-top:.6rem;}
.idrop:hover{border-color:var(--g);color:var(--g);}
#iprev{max-width:100%;max-height:95px;border-radius:var(--rs);margin-top:.5rem;display:none;}
/* voice status */
.vs{background:var(--gl);border:1px solid var(--g);border-radius:var(--rs);padding:.6rem .9rem;font-size:.8rem;color:var(--gd);margin-bottom:.6rem;display:none;line-height:1.5;word-break:break-word;}
.vs.on{display:block;}
/* product cards */
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:.8rem;}
.pc{background:var(--w);border-radius:var(--r);border:1px solid var(--bd);padding:.85rem;position:relative;box-shadow:var(--sh);transition:transform .15s;}
.pc:hover{transform:translateY(-2px);}
.pc img,.nimg{width:100%;height:95px;object-fit:cover;border-radius:var(--rs);margin-bottom:.55rem;}
.nimg{background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:28px;}
.pn{font-weight:700;font-size:.9rem;margin-bottom:3px;} .pd{font-size:.76rem;color:var(--tx2);margin-bottom:.4rem;line-height:1.4;}
.pm{display:flex;justify-content:space-between;align-items:center;}
.ptag{font-weight:800;color:var(--gd);font-size:.92rem;}
.ltag,.stag,.ctag{font-size:10px;padding:2px 7px;border-radius:20px;font-weight:600;}
.ltag{background:var(--gl);color:var(--gd);} .stag{background:var(--ol);color:var(--od);} .ctag{background:var(--bg);color:var(--tx2);border:1px solid var(--bd);}
.svtag{font-size:10px;color:var(--gd);font-weight:700;}
.dbtn{position:absolute;top:7px;right:7px;background:none;border:none;color:#ccc;cursor:pointer;font-size:14px;} .dbtn:hover{color:#d93025;}
.cas{display:flex;gap:4px;margin-top:.55rem;}
.cb{flex:1;padding:5px 3px;border-radius:7px;border:1px solid var(--bd);background:var(--bg);font-size:11px;cursor:pointer;font-weight:600;color:var(--tx2);transition:.15s;}
.cb:hover{background:var(--gl);color:var(--gd);border-color:var(--g);}
.cbb{background:var(--g);color:#fff;border-color:var(--g);} .cbb:hover{background:var(--gd);}
.empty{text-align:center;padding:2.5rem 1rem;color:var(--tx2);} .ei{font-size:42px;margin-bottom:.75rem;}
/* search */
.sb{display:flex;gap:.4rem;margin-bottom:.9rem;} .sb .inp{flex:1;}
.vsb{padding:.6rem .75rem;border-radius:var(--rs);border:1px solid var(--g);background:var(--gl);color:var(--gd);font-weight:700;font-size:14px;cursor:pointer;transition:.2s;}
.vsb:hover,.vsb.on{background:var(--g);color:#fff;} .vsb.on{animation:pulse 1s infinite;}
.sb button:last-child{padding:.6rem .85rem;border-radius:var(--rs);border:none;background:var(--g);color:#fff;font-weight:600;cursor:pointer;}
/* chips */
.chips{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.85rem;}
.chip{padding:4px 12px;border-radius:20px;border:1px solid var(--bd);background:var(--w);font-size:11px;cursor:pointer;color:var(--tx2);transition:all .15s;}
.chip.on,.chip:hover{background:var(--gl);color:var(--gd);border-color:var(--g);}
/* modal */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.52);z-index:200;align-items:flex-end;justify-content:center;}
.ov.open{display:flex;}
.modal{background:var(--w);border-radius:18px 18px 0 0;padding:1.5rem;width:100%;max-width:480px;max-height:88vh;overflow-y:auto;}
.mh{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;}
.mh h3{font-size:.95rem;font-weight:700;} .mcl{background:none;border:none;font-size:20px;cursor:pointer;color:var(--tx2);}
/* cart */
.csec{margin-bottom:1.2rem;}
.csh{display:flex;align-items:center;gap:6px;font-size:.8rem;font-weight:700;color:var(--gd);background:var(--gl);padding:.4rem .7rem;border-radius:var(--rs);margin-bottom:.5rem;}
.ci{display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--bd);}
.ci:last-child{border-bottom:none;}
.cin{font-weight:600;font-size:.88rem;} .cis{font-size:.73rem;color:var(--tx2);}
.cir{display:flex;align-items:center;gap:.45rem;} .cip{font-weight:800;color:var(--gd);}
.qst{display:flex;align-items:center;gap:4px;}
.qb{width:25px;height:25px;border-radius:50%;border:1px solid var(--bd);background:var(--bg);cursor:pointer;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;transition:.15s;}
.qb:hover{background:var(--gl);border-color:var(--g);} .qn{min-width:20px;text-align:center;font-weight:700;font-size:.88rem;}
.ctot{font-size:.95rem;font-weight:800;color:var(--gd);text-align:right;padding:.6rem 0 0;}
.dinfo{font-size:.78rem;color:var(--tx2);text-align:right;margin-top:2px;}
.wabtn{width:100%;margin-top:.6rem;padding:.7rem;border-radius:var(--rs);border:none;background:#25D366;color:#fff;font-size:.9rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:.15s;}
.wabtn:hover{background:#1da855;}
/* compare */
.ctbl{width:100%;border-collapse:collapse;font-size:.83rem;margin:.7rem 0;}
.ctbl th{background:var(--gd);color:#fff;padding:.4rem .65rem;text-align:left;font-size:.73rem;}
.ctbl td{padding:.4rem .65rem;border-bottom:1px solid var(--bd);}
.ctbl .best td{background:var(--gl);font-weight:700;}
.vsbar{background:var(--bg);border-radius:var(--rs);padding:.6rem;font-size:.8rem;color:var(--tx2);margin-top:.5rem;}
.vsbar .sv2{color:var(--gd);font-weight:700;}
.mchip{background:var(--ol);color:var(--od);font-size:10px;padding:2px 7px;border-radius:20px;font-weight:700;}
/* toast */
#toast{position:fixed;bottom:1.25rem;left:50%;transform:translateX(-50%) translateY(60px);background:var(--gd);color:#fff;padding:.55rem 1.1rem;border-radius:var(--rs);font-size:.83rem;opacity:0;transition:all .3s;pointer-events:none;z-index:999;white-space:nowrap;box-shadow:0 4px 16px rgba(0,0,0,.2);max-width:92vw;text-align:center;}
#toast.on{transform:translateX(-50%) translateY(0);opacity:1;}
#offline{display:none;background:var(--ol);border-bottom:1px solid var(--o);padding:5px 1rem;font-size:12px;color:var(--od);text-align:center;}
.ibtn{display:flex;align-items:center;gap:6px;background:var(--gl);border:1px solid var(--g);color:var(--gd);border-radius:20px;padding:5px 14px;font-size:12px;font-weight:600;cursor:pointer;margin:0 auto .8rem;transition:.2s;}
.ibtn:hover{background:var(--g);color:#fff;}
.lsel{background:transparent;border:1px solid rgba(255,255,255,.4);color:#fff;padding:3px 7px;border-radius:6px;font-size:12px;cursor:pointer;max-width:90px;}
.lsel option{color:var(--tx);background:#fff;}
@media(max-width:400px){.g2{grid-template-columns:1fr;}.pgrid{grid-template-columns:1fr 1fr;}.roles{grid-template-columns:1fr 1fr;}}

/* ═══ FRESHNESS RATING SYSTEM ═══ */
.fr-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;margin-top:4px;}
.fr-fresh{background:#d4f5e0;color:#1a6b38;}
