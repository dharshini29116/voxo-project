.fr-trait{display:flex;align-items:center;justify-content:space-between;background:var(--w);border:1px solid var(--bd);border-radius:8px;padding:.35rem .6rem;font-size:.75rem;}
.fr-trait-label{color:var(--tx2);}
.fr-trait-val{font-weight:700;}
.fr-comm-panel{background:var(--gl);border:1.5px solid var(--g);border-radius:var(--r);padding:.9rem;margin-top:.75rem;}
.fr-comm-title{font-size:.8rem;font-weight:700;color:var(--gd);margin-bottom:.5rem;}
.fr-comm-msg{font-size:.82rem;color:var(--tx);background:var(--w);border-radius:8px;padding:.6rem .75rem;margin-bottom:.5rem;border:1px solid var(--bd);line-height:1.5;}
.fr-tips{font-size:.75rem;color:var(--tx2);margin-top:.4rem;}
.fr-tip-item{display:flex;align-items:flex-start;gap:5px;margin:.25rem 0;}
.freshness-btn{display:flex;align-items:center;gap:5px;padding:4px 9px;border-radius:8px;border:1.5px solid var(--g);background:var(--gl);color:var(--gd);font-size:11px;font-weight:700;cursor:pointer;transition:.15s;white-space:nowrap;margin-top:.3rem;}
.freshness-btn:hover{background:var(--g);color:#fff;}
.fr-analyzing{display:flex;flex-direction:column;align-items:center;gap:.6rem;padding:1.2rem;color:var(--gd);}
.fr-spinner{width:40px;height:40px;border:4px solid var(--gl);border-top-color:var(--g);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.fr-wa-btn{width:100%;margin-top:.6rem;padding:.65rem;border-radius:var(--rs);border:none;background:#25D366;color:#fff;font-size:.88rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:.15s;}
.fr-wa-btn:hover{background:#1da855;}
.fr-farmer-panel{background:var(--w);border-radius:var(--r);border:1px solid var(--bd);padding:1.1rem;margin-top:1rem;box-shadow:var(--sh);}
.fr-farmer-title{font-size:.78rem;font-weight:700;color:var(--tx2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.6rem;}
.fr-cert-badge{display:inline-flex;align-items:center;gap:5px;background:linear-gradient(135deg,#2d6a4f,#52b788);color:#fff;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;margin-bottom:.6rem;}

/* ═══ PRICE ENGINE ═══ */
.pe-signal{background:var(--bg);border:1px solid var(--bd);border-radius:8px;padding:.45rem .6rem;font-size:.73rem;}
