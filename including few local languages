  document.getElementById("pe-product").focus();
}

function closePE(){
  document.getElementById("pe-ov").classList.remove("open");
  document.getElementById("pe-suggestions").style.display="none";
}

function pe_onInput(){
  const q = document.getElementById("pe-product").value.toLowerCase().trim();
  const sug = document.getElementById("pe-suggestions");
  if(q.length < 2){sug.style.display="none";return;}
  const matches = Object.keys(PE_DATA).filter(k=>k.includes(q)).slice(0,6);
  if(matches.length===0){sug.style.display="none";return;}
  sug.style.display="block";
  sug.innerHTML = matches.map(m=>`<div style="padding:.45rem .75rem;cursor:pointer;border-bottom:1px solid var(--bd);" onmousedown="document.getElementById('pe-product').value='${m}';document.getElementById('pe-suggestions').style.display='none';">${m.charAt(0).toUpperCase()+m.slice(1)}</div>`).join("");
}

function getPEKey(name){
  const n = name.toLowerCase().trim();
  for(const k of Object.keys(PE_DATA)){if(n.includes(k)||k.includes(n))return k;}
  return null;
}

function runPriceEngine(){
  const name = document.getElementById("pe-product").value.trim();
  if(!name){toast("Enter a product name first");return;}
  document.getElementById("pe-suggestions").style.display="none";
  document.getElementById("pe-empty").style.display="none";
  document.getElementById("pe-results").style.display="none";
  document.getElementById("pe-loading").style.display="block";

  const msgs=["Analyzing market trends…","Checking seasonal patterns…","Evaluating demand signals…","Calculating optimal range…"];
  let mi=0;
  const lmsg=document.getElementById("pe-loading-msg");
  lmsg.textContent=msgs[0];
  const lInt=setInterval(()=>{mi=(mi+1)%msgs.length;lmsg.textContent=msgs[mi];},700);

  setTimeout(()=>{
    clearInterval(lInt);
    document.getElementById("pe-loading").style.display="none";
    renderPEResults(name);
  }, 2200);
}

function renderPEResults(name){
  const key = getPEKey(name);
  const quality = document.getElementById("pe-quality").value;
  const qty = document.getElementById("pe-qty").value;

  // Get or synthesize base data
  let base, seasonal, demand, volatility, unit;
  if(key && PE_DATA[key]){
    ({b:base, s:seasonal, d:demand, v:volatility, unit} = PE_DATA[key]);
  } else {
    // Synthesize from MKT or default
    base = MKT[name.toLowerCase()] || 40;
    seasonal = 0.1; demand = 0.6; volatility = 0.4; unit = "kg";
  }

  // Season factor (Tamil Nadu: summer=Apr-Jun, harvest=Oct-Jan)
  const month = new Date().getMonth(); // 0-11
  const seasonMod = (month>=3&&month<=5) ? seasonal*1.3 :   // summer — peak demand
                    (month>=9&&month<=12) ? seasonal*-0.7 :  // harvest — supply high
                    seasonal*0.5;

  const qMult = PE_QUALITY_MULT[quality] || 1;
  const qtyMult = PE_QTY_MULT[qty] || 1;

  // Demand-driven price lift
  const demandBoost = 1 + (demand - 0.5) * 0.25;

  const adjBase = base * (1 + seasonMod) * demandBoost;
  const optimal = Math.round(adjBase * qMult * qtyMult);
  const low = Math.round(optimal * (1 - volatility * 0.35));
  const high = Math.round(optimal * (1 + volatility * 0.28));

  peCurrentOpt = optimal;

  // Update banner
  document.getElementById("pe-low").textContent = "₹"+low;
  document.getElementById("pe-opt").textContent = "₹"+optimal;
  document.getElementById("pe-high").textContent = "₹"+high;
  document.getElementById("pe-unit-label").textContent = "per "+unit;

  // Draw trend chart
  drawPEChart(base, volatility, seasonal, month);

  // Signals
  const volLabel = volatility>0.5?"High":volatility>0.3?"Moderate":"Stable";
  const volClass = volatility>0.5?"pe-sig-down":volatility>0.3?"pe-sig-flat":"pe-sig-up";
  const seasonLabel = seasonMod>0.1?"📈 Favourable":seasonMod<-0.05?"📉 Off-season":"➡️ Neutral";
  const seasonClass = seasonMod>0.1?"pe-sig-up":seasonMod<-0.05?"pe-sig-down":"pe-sig-flat";
  const demandLabel = demand>0.75?"🔥 High":demand>0.5?"📊 Moderate":"🌀 Low";
  const demandClass = demand>0.75?"pe-sig-up":demand>0.5?"pe-sig-flat":"pe-sig-down";
  const qtyLabel = {small:"Limited supply",medium:"Moderate supply",large:"High supply",bulk:"Bulk / wholesale"}[qty];
  const qtyClass = qty==="small"?"pe-sig-up":qty==="bulk"?"pe-sig-down":"pe-sig-flat";

  const signals = [
    {label:"Market Volatility", val:volLabel, cls:volClass},
    {label:"Season Trend", val:seasonLabel, cls:seasonClass},
    {label:"Consumer Demand", val:demandLabel, cls:demandClass},
    {label:"Supply Volume", val:qtyLabel, cls:qtyClass},
    {label:"Market Ref Price", val:"₹"+base+"/"+unit, cls:"pe-sig-flat"},
    {label:"Quality Premium", val:({premium:"+18%",good:"±0%",fair:"-18%"})[quality], cls:quality==="premium"?"pe-sig-up":quality==="fair"?"pe-sig-down":"pe-sig-flat"},
  ];
  document.getElementById("pe-signals").innerHTML = signals.map(s=>`
    <div class="pe-signal">
      <div class="pe-signal-label">${s.label}</div>
      <div class="pe-signal-val ${s.cls}">${s.val}</div>
    </div>`).join("");

  // Rationale
  const seasonText = seasonMod>0.1 ? "Seasonal demand is currently strong, which supports higher pricing." : seasonMod<-0.05 ? "This is a harvest season — supply is high, so prices are softened." : "Seasonal conditions are neutral.";
  const demandText = demand>0.75 ? "Consumer demand for this product is high — buyers expect to pay fair prices." : demand>0.5 ? "Demand is moderate and stable." : "Demand is lower than average; competitive pricing will help you sell faster.";
  const qtyText = qty==="small" ? "Your limited stock lets you price slightly higher — scarcity is an advantage." : qty==="bulk" ? "With bulk quantities, pricing competitively will attract wholesale buyers." : "Your stock level is typical for the market.";
  document.getElementById("pe-rationale").textContent = `${seasonText} ${demandText} ${qtyText} The optimal price of ₹${optimal}/${unit} is calculated from the market reference (₹${base}), quality grade (${quality}), and current demand-supply conditions.`;

  document.getElementById("pe-results").style.display="block";
  toast("📈 Price analysis ready!");
}

function drawPEChart(base, volatility, seasonal, month){
  const canvas = document.getElementById("pe-chart");
  const ctx = canvas.getContext("2d");
  canvas.width = canvas.offsetWidth * window.devicePixelRatio || 300;
  canvas.height = 100 * window.devicePixelRatio || 100;
  ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  const W = canvas.offsetWidth, H = 100;
  ctx.clearRect(0,0,W,H);

  const pts = 30;
  const prices = [];
  // Seeded pseudo-random for consistency (based on base+month)
  let seed = base * 7 + month * 13;
  function rng(){seed=(seed*1664525+1013904223)&0xffffffff;return(seed>>>0)/0xffffffff;}

  for(let i=0;i<pts;i++){
    const trend = seasonal * 0.3 * (i/pts);
    const noise = (rng()-0.5)*volatility*base*0.5;
    const momentum = i>0 ? (prices[i-1]-base)*0.3 : 0;
    prices.push(Math.max(base*0.4, base*(1+trend) + noise - momentum*0.4));
  }

  const minP = Math.min(...prices), maxP = Math.max(...prices);
  const pad = 8;
  const toY = v => pad + (1-(v-minP)/(maxP-minP||1))*(H-pad*2);
  const toX = i => (i/(pts-1))*(W-pad*2)+pad;

  // Gradient fill
  const grad = ctx.createLinearGradient(0,0,0,H);
  grad.addColorStop(0,"rgba(45,106,79,.25)");
  grad.addColorStop(1,"rgba(45,106,79,.02)");
  ctx.beginPath();
  ctx.moveTo(toX(0),toY(prices[0]));
  for(let i=1;i<pts;i++) ctx.lineTo(toX(i),toY(prices[i]));
  ctx.lineTo(toX(pts-1),H);ctx.lineTo(toX(0),H);ctx.closePath();
  ctx.fillStyle=grad;ctx.fill();

  // Line
  ctx.beginPath();
  ctx.moveTo(toX(0),toY(prices[0]));
  for(let i=1;i<pts;i++) ctx.lineTo(toX(i),toY(prices[i]));
  ctx.strokeStyle="#2D6A4F";ctx.lineWidth=2;ctx.lineJoin="round";ctx.stroke();

  // Baseline (market base)
  const byVal = toY(base);
  ctx.beginPath();ctx.moveTo(pad,byVal);ctx.lineTo(W-pad,byVal);
  ctx.strokeStyle="rgba(244,162,97,.7)";ctx.lineWidth=1;ctx.setLineDash([4,3]);ctx.stroke();ctx.setLineDash([]);

  // Labels
  ctx.fillStyle="#2D6A4F";ctx.font="bold 9px sans-serif";ctx.textAlign="right";
  ctx.fillText("₹"+Math.round(maxP),W-2,pad+7);
  ctx.fillStyle="#856404";ctx.textAlign="left";
  ctx.fillText("base ₹"+base,pad+2,byVal-3);
}

function applyPEPrice(){
  if(!peCurrentOpt) return;
  document.getElementById("pprice").value = peCurrentOpt;
  // Also fill product name if empty
  const pname = document.getElementById("pname");
  const peval = document.getElementById("pe-product").value.trim();
