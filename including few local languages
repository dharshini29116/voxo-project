const PE_QUALITY_MULT = {premium:1.18, good:1.0, fair:0.82};
const PE_QTY_MULT = {small:1.08, medium:1.0, large:0.93, bulk:0.86};

let peCurrentOpt = 0;

function openPriceEngine(){
  // Pre-fill product name from the form
  const name = document.getElementById("pname").value.trim();
  if(name) document.getElementById("pe-product").value = name;
  document.getElementById("pe-results").style.display="none";
  document.getElementById("pe-loading").style.display="none";
